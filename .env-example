# Application Configuration
APP_NAME=Kira API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Database Configuration
DATABASE_URL=postgresql+asyncpg://kira:kira@localhost:5432/kira
DATABASE_ECHO=false

# Profile Fixture Configuration
PROFILE_FIXTURE_PATH=src/modules/profiles/fixtures/parent_profiles.json

# Redis Configuration (for Dramatiq)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
VOICE_SESSION_REDIS_PREFIX=kira:voice
VOICE_SESSION_TTL_SECONDS=3600

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# API Configuration
API_PREFIX=/api/v1

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30
LLM_REASONING_EFFORT=low
MAX_CONTEXT_MESSAGES=12
CONVERSATION_SUMMARY_INITIAL_THRESHOLD_TURNS=10
CONVERSATION_SUMMARY_REFRESH_INTERVAL_TURNS=3
LLM_INPUT_COST_PER_MILLION_TOKENS_USD=
LLM_CACHED_INPUT_COST_PER_MILLION_TOKENS_USD=
LLM_OUTPUT_COST_PER_MILLION_TOKENS_USD=
OPENAI_API_KEY=replace-with-real-key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

# Retell Integration
RETELL_API_KEY=replace-with-real-retell-key
RETELL_INBOUND_VOICE_AGENT_ID=
RETELL_DEFAULT_BEGIN_MESSAGE=Hello, this is Kira. How can I help today?
RETELL_VERIFY_SIGNATURES=true
RETELL_WEBHOOK_MAX_AGE_MS=300000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT="<green>{time:YYYY-MM-DD HH:mm:ss.SSS}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>"
